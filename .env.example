# Copy this file to .env for local development.
# Then run: docker compose up --build

# Runtime mode
ENVIRONMENT=development

# Local development keeps auth off by default in docker-compose.yml.
# If you turn it on locally, use these values in the login screen and scripts.
AUTH_ENABLED=false
AUTH_USERNAME=soc_operator
AUTH_PASSWORD=change-me-locally
AUTH_TOKEN_SECRET=local-dev-token-secret
AUTH_TOKEN_TTL_MINUTES=480
AUTH_MFA_ENABLED=false
AUTH_TOTP_SECRET=
AUTH_TOTP_ISSUER=Ataraxia

# Optional local rate limiting. The dev compose file keeps this off by default.
RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_REQUESTS=300
API_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# CORS / host restrictions
# - Use localhost when running everything on the Ubuntu VM
# - Keep the Windows host IP (<WIN_HOST_IP>) so the API accepts calls from your browser/dev server on Windows
# - Include the VM IP (<SOC_UBUNTU_IP>) so direct browser/API calls from another host work too
CORS_ORIGINS=http://localhost:3000,http://<WIN_HOST_IP>:3000,http://<SOC_UBUNTU_IP>:3000
ALLOWED_HOSTS=localhost,127.0.0.1,<WIN_HOST_IP>,<SOC_UBUNTU_IP>,testserver,backend
ENABLE_API_DOCS=true

# Claude integration is optional.
# Without this key the platform still works with template-based fallback responses.
ANTHROPIC_API_KEY=
# Default model (cheapest by default); override with your preferred model ID.
ANTHROPIC_MODEL=claude-3-haiku
# Control cost: auto AI on incident creation is off by default. Set true to enable.
AI_AUTO_ENABLED=false

# Database credentials for local development
POSTGRES_USER=soc
POSTGRES_PASSWORD=soc_pass
POSTGRES_DB=soc_db

# Event / queue (optional in dev; enabled in prod compose)
USE_REDIS_STREAMS=true
REDIS_URL=redis://redis:6379/0
LOG_RETENTION_MINUTES=15

# Disable demo data (assets, threat intel) and set your primary asset
SEED_DEMO_DATA=false
PRIMARY_ASSET_HOSTNAME=soc-ubuntu
PRIMARY_ASSET_IP=<SOC_UBUNTU_IP>
# Agent token for local log forwarder (sent as X-Agent-Token)
INGEST_TOKEN=lab-ingest-token
